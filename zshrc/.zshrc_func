BASE_DIR="${HOME}/Code"

SCRIPTS_DIR="${BASE_DIR}/dotfiles/_scripts"

jh () {
  echo "jh -> Show this help"
  echo "jg -> Open github project in browser"
  echo "jga -> Open github actions in browser"
  echo "jl -> Open Brave Bookmarks"
  echo "jprs -> List open PRs for repos and users"
  echo "tt -> change project"
  echo "up -> go to root dir of git project"
  echo "cmotd -> Show a random Claude tip"
  echo "creport -> Show latest Claude usage report"
}

jg () {
    up
    LINK=$(cat .git/config | grep url | cut -d "=" -f 2 | sed "s/ //")
    if [[ "$LINK" == git@* ]]; then
      open $(echo $LINK | sed "s/:/\//" | sed "s/git@/https:\/\//" | sed "s/.git$//")
    else
      open $LINK
    fi
}


tt() {
    selected_directory=$(cat ${HOME}/Code/dotfiles/tmuxinator/.tmuxinator/* | grep name | sed 's/name: //' | sort | fzf)

    if [[ -n $selected_directory ]]; then
        tmuxinator start $selected_directory
    else
        echo "No directory selected."
        return 1
    fi
}

up() {
  NEWDIR=$(git rev-parse --show-toplevel)
  if [ -d "$NEWDIR" ]; then
    echo "cd to ${NEWDIR}"
    cd "$NEWDIR" || return
  else
    echo "Not a git repository (or any of the parent directories): .git"
  fi
}

bk() {
    branch=$(git rev-parse --abbrev-ref HEAD | sed 's|/|%2F|g')
    project=$(git remote get-url origin | sed 's|.*github.com[:/]\([^/]*\)/\([^.]*\).*|\2|')
    open "https://buildkite.com/culture-amp/${project}/builds?branch=${branch}"
}

js() {
    OUTPUT_DIR="$HOME/Code/notes/quick_notes"
    TIMESTAMP=$(date -u +"%Y-%m-%d_%H-%M-%S")
    FILENAME="${TIMESTAMP}_UTC.txt"
    mkdir -p "$OUTPUT_DIR"
    if [ -z "$(pbpaste)" ]; then
      echo "Clipboard is empty!"
      exit 1
    fi
    pbpaste > "$OUTPUT_DIR/$FILENAME"
}

cmotd() {
    local tips_dir="$HOME/Code/ai/notes/claude_tips_and_tricks"
    local files=("$tips_dir"/tip_*.md)
    local file="${files[$RANDOM % ${#files[@]}]}"
    if command -v glow &>/dev/null; then
        glow "$file"
    else
        cat "$file"
    fi
}

creport() {
    local insights_dir=~/Code/ai/notes/claude_insights
    local latest=$(ls "$insights_dir"/*.md 2>/dev/null | sort | tail -1)
    local run_cmd="~/.claude_tracker/run-digest.sh"

    if [[ -z "$latest" ]]; then
        echo "No reports found. Generate one with:"
        echo "  $run_cmd"
        return 1
    fi

    local today=$(date +%Y-%m-%d)
    local report_date=$(basename "$latest" .md)

    if [[ "$report_date" != "$today" ]]; then
        echo "⚠️  Last report is from $report_date (today is $today)."
        echo "   The 09:10 cron may have failed. Check: cat /tmp/claude-digest-error.log"
        echo "   To run manually: $run_cmd"
        echo ""
    fi

    if command -v glow &>/dev/null; then
        glow "$latest"
    else
        cat "$latest"
    fi
}
