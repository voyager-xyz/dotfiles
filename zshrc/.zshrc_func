BASE_DIR="${HOME}/Code"

SCRIPTS_DIR="${BASE_DIR}/dotfiles/_scripts"

,m () {
    find ~/.claude/projects -name "*.md" -path "*/memory/*" | fzf | xargs cat
}

,h () {
  echo ",h -> Show this help"
  echo ",g -> Open github project in browser"
  echo ",m -> Claude memory"
  echo ",b -> Open buildkite"
  echo ",p -> Open GitHub PR for current branch"
  echo ",sad -> Interactive find & replace with preview (sad)"
  echo "tt -> change project"
  echo "up -> go to root dir of git project"
}

,g () {
    up
    LINK=$(cat .git/config | grep url | cut -d "=" -f 2 | sed "s/ //")
    if [[ "$LINK" == git@* ]]; then
      open $(echo $LINK | sed "s/:/\//" | sed "s/git@/https:\/\//" | sed "s/.git$//")
    else
      open $LINK
    fi
}


tt() {
    selected_directory=$(cat ${HOME}/Code/dotfiles/tmuxinator/.tmuxinator/* | grep name | sed 's/name: //' | sort | fzf)

    if [[ -n $selected_directory ]]; then
        tmuxinator start $selected_directory
    else
        echo "No directory selected."
        return 1
    fi
}

up() {
  NEWDIR=$(git rev-parse --show-toplevel)
  if [ -d "$NEWDIR" ]; then
    echo "cd to ${NEWDIR}"
    cd "$NEWDIR" || return
  else
    echo "Not a git repository (or any of the parent directories): .git"
  fi
}

,p() {
    # Open the GitHub PR for the current branch; if none exists yet, open the
    # PR-create page instead.
    gh pr view --web 2>/dev/null || gh pr create --web
}

,sad() {
    # Interactive find & replace with a per-line diff preview.
    # Usage: ,sad <find> <replace> [filetype]
    #   ,sad oldName newName          # search all files
    #   ,sad oldName newName lua      # only *.lua files
    # In the fzf preview:
    #   Tab        add/omit the entry under the cursor (toggle)
    #   Shift-Tab  same, moving up
    #   Ctrl-A     select all
    #   Ctrl-X     clear selection
    #   Enter      apply only the selected entries (or the one under the
    #              cursor if nothing is selected)
    #   Esc        abort, write nothing
    if [[ -z "$1" ]]; then
        echo "Usage: ,sad <find> <replace> [filetype]"
        return 1
    fi
    # Search every file (including hidden dotfiles), but never descend into .git.
    local -a files=(fd -t f --hidden --exclude .git)
    # Optional 3rd arg narrows to a single extension, e.g. `,sad foo bar lua`.
    if [[ -n "$3" ]]; then
        files+=(-e "$3")
    fi
    local fzf_opts='--multi --bind=tab:toggle+down,shift-tab:toggle+up,ctrl-a:select-all,ctrl-x:deselect-all --header-first --header="Tab add/omit | ^A all | ^X clear | Enter apply | Esc cancel"'
    "${files[@]}" | sad -u 0 --fzf="$fzf_opts" --pager 'delta' "$1" "$2"
}

,b() {
    branch=$(git rev-parse --abbrev-ref HEAD | sed 's|/|%2F|g')
    project=$(git remote get-url origin | sed 's|.*github.com[:/]\([^/]*\)/\([^.]*\).*|\2|')
    open "https://buildkite.com/culture-amp/${project}/builds?branch=${branch}"
}

creport() {
    local insights_dir=~/Code/ai/notes/claude_insights
    local latest=$(ls "$insights_dir"/*.md 2>/dev/null | sort | tail -1)
    local run_cmd="~/.claude_tracker/run-digest.sh"

    if [[ -z "$latest" ]]; then
        echo "No reports found. Generate one with:"
        echo "  $run_cmd"
        return 1
    fi

    local today=$(date +%Y-%m-%d)
    local report_date=$(basename "$latest" .md)

    if [[ "$report_date" != "$today" ]]; then
        echo "⚠️  Last report is from $report_date (today is $today)."
        echo "   The 09:10 cron may have failed. Check: cat /tmp/claude-digest-error.log"
        echo "   To run manually: $run_cmd"
        echo ""
    fi

    if command -v glow &>/dev/null; then
        glow "$latest"
    else
        cat "$latest"
    fi
}

# Tint the tab/pane red while an SSH session is active, so remote shells are
# visually distinct from local ones. Inside tmux we color the active pane; on a
# bare Ghostty tab we recolor the surface via OSC 11. The `always` block
# guarantees the color is reset on exit — even on Ctrl-C or error.
#
# Handing keyboard control to the remote tmux is done separately, in tmux.conf,
# via focus hooks keyed on the pane running ssh (see "Nested tmux" there) — so
# it applies only while the ssh tab is focused, not for the ssh process's whole
# lifetime.
ssh() {
    local ssh_bg="#3a1a1a"
    if [[ -n "$TMUX" ]]; then
        tmux select-pane -P "bg=${ssh_bg}"
    else
        printf '\033]11;%s\007' "$ssh_bg"
    fi

    {
        command ssh "$@"
    } always {
        if [[ -n "$TMUX" ]]; then
            tmux select-pane -P 'bg=default'
        else
            printf '\033]111\007'
        fi
    }
}
