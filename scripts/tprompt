#!/bin/zsh
set -euo pipefail

usage() {
  print -u2 -- "usage: tprompt [i|r]   (i = implementation [default], r = research)"
  exit 2
}

MODE="i"
(( $# > 0 )) && MODE="$1"
case "$MODE" in
  i|r) ;;
  *) usage ;;
esac

OUT="task-prompt.md"

if [[ -e "$OUT" ]]; then
  print -u2 -- "$OUT already exists in $(pwd) — refusing to overwrite"
  exit 1
fi

REPO=""
if TOPLEVEL=$(git rev-parse --show-toplevel 2>/dev/null); then
  REPO=$(basename "$TOPLEVEL")
fi
[[ -z "$REPO" ]] && REPO="<repo-name>"

# Parts A and B are identical for both modes; only Part C (below) differs.
cat > "$OUT" <<'EOF'
# Task Prompt — __REPO__

> Paste this entire file into a fresh Claude Code conversation, filled in for the task at hand. Sections you don't need can be left blank — Claude will skip them silently.

---

## Instructions to Claude

You are starting a task in the `__REPO__` repository. Before doing anything else, load context as follows:

1. **Read `CLAUDE.md`** at the project root for repo-level context (architecture, build/test commands, conventions). This is required even if every other section below is empty.

2. **For each populated section in Part B, fetch the referenced material upfront, in parallel where possible:**
   - **Atlassian Links** — fetch via the Atlassian MCP. Use `getJiraIssue` for Jira URLs (`/browse/<KEY>`) and `getConfluencePage` for Confluence URLs (`/wiki/spaces/...`). If a Jira ticket references linked issues that look relevant, fetch those too.
   - **Related pull requests** — fetch the full PR description, diff, and review comments via the GitHub MCP using `pull_request_read`. Treat both open and merged PRs as authoritative context.
   - **Links** — pointers to external/community references. Use `WebFetch` only when a deliverable explicitly calls for external corroboration; otherwise treat as background.
   - **Associated GitHub projects** — for each entry, check whether `.other_projects/<repo-name>` already exists. If it does, skip. If not, `git clone <url> .other_projects/<repo-name>` (creating `.other_projects/` first if needed). After cloning, treat the contents as **read-only** under the same rules as the next section.
   - **Files in this repo** — read with the `Read` tool.
   - **Files in `.other_projects/`** — read with the `Read` tool. **Read-only.** Never edit files in `.other_projects/`, never propose changes inside that directory, and never include those paths in any commit. The folder holds gitignored sibling checkouts kept purely for cross-reference.

3. **Skip any empty section silently.** Do not warn, do not ask the user to fill it in, do not list missing fields.

4. **If a fetch fails** (broken URL, missing permission, file not found, clone error), stop and tell the user which specific reference failed and why.

5. **Your first response after loading context must be:**
   - A short summary (a few bullets) of what you loaded and how you understand the task.
   - Targeted clarifying questions if anything is ambiguous. If nothing is ambiguous, say so. If there are more than ~5 questions, write them to a `questions.md` at the repo root instead of inline and point the user to it.
   - Then **wait** for the user to confirm or answer. Do not propose an implementation plan, do not edit code, do not run builds.

---

## Part B — Task context

### Task summary

<one or two sentences describing the work. Optionally add a **Working hypothesis to verify or falsify:** line and a **Deliverables (treat as a checklist):** numbered list when the task is investigative — leave blank to skip>

### Known facts / pre-loaded context (verify, don't assume)

<bullet list of facts already known about the system that Claude should verify against the loaded sources rather than assume — leave blank to skip>

### Atlassian Links

<one URL per line — Jira `/browse/<KEY>` or Confluence `/wiki/spaces/...`. Leave blank to skip>

### Related pull requests

<one URL per line, open or merged — leave blank to skip>

### Links

<one URL per line — external/community references (docs, support articles, source on GitHub, etc.). Leave blank to skip>

### Associated GitHub projects

<one repo per line — full clone URL (`git@github.com:org/repo.git` or `https://github.com/org/repo.git`) or `org/repo` shorthand. Claude will clone any that aren't already present under `.other_projects/<repo-name>`. Leave blank to skip>

### Files in this repo to read

<one repo-relative path per line — leave blank to skip>

### Files in `.other_projects/` to read (read-only)

<one path per line, e.g. `.other_projects/comment-summary-service/...` — leave blank to skip>

### Constraints / non-goals

<anything Claude should avoid, or items explicitly out of scope — leave blank to skip>

---

EOF

if [[ "$MODE" == "i" ]]; then
  cat >> "$OUT" <<'EOF'
## Part C — Output

This is an **implementation** task. Deliver as follows:

- Make the code changes in this repo, but **leave them uncommitted** — do not `git commit`, `git push`, or open a PR. The user commits and pushes manually.
- Write an `assumptions.md` at the repo root recording the decisions and assumptions you made: anything you inferred rather than confirmed, alternatives you rejected, and anything the user should double-check. Keep it concise.

<task-specific delivery notes — leave blank to skip>
EOF
else
  cat >> "$OUT" <<'EOF'
## Part C — Output

This is a **pure research** task. Do not modify code, commit, or open a PR.

- Deliver your findings as a single Markdown file at the repo root (e.g. `findings.md`) with clear subheadings, or inline in the conversation if the user prefers.
- Cite the sources behind each conclusion (file paths with line numbers, PR/Jira/Confluence links) so it can be traced.

<task-specific delivery notes — leave blank to skip>
EOF
fi

# Substitute repo name (sentinel pattern avoids escaping every $ and ` in the heredoc).
sed -i.bak "s|__REPO__|${REPO}|g" "$OUT" && rm "${OUT}.bak"

print -- "wrote ./$OUT (${MODE} mode)"
