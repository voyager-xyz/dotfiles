fullscreen = false
maximize = true
shell-integration = zsh


## Window
window-decoration = true
mouse-hide-while-typing = true
window-padding-x = 8
window-padding-y = 8
macos-window-shadow = false

## Clipboard
clipboard-read = "allow"
clipboard-paste-protection = false

## Theme
theme = Molokai
font-family = FiraCode Nerd Font
font-size = 20

adjust-cell-width = 3%
adjust-cell-height = 20%
